  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The onboarding process for new college students is a critical phase in
    their academic journey. This transition\u2014from senior high school to university
    or from another institution to BukSU\u2014comes with both challenges and opportunities
    that greatly affect students\u2019 academic and social experience. Effective
    onboarding helps students develop a sense of belonging and supports their academic
    and personal growth. However, students are often overwhelmed by the amount of
    information presented during orientation, making it difficult to remember or
    apply what they have learned."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
